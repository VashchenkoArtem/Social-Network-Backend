model Album {
  id        Int      @id @default(autoincrement())
  title     String
  isVisible Boolean  @default(true)

  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int

  topic     Tag      @relation(fields: [topicId], references: [id]) 
  topicId   Int

  year      AlbumYear @relation(fields: [yearId], references: [id]) 
  yearId    Int

  photos    Photo[]
}
model Photo {
  id        Int     @id @default(autoincrement())
  filename  String
  
  album     Album?  @relation(fields: [albumId], references: [id])
  albumId   Int?

  user      User?   @relation(fields: [userId], references: [id])
  userId    Int?

  avatarFor User?   @relation("UserAvatars", fields: [avatarForId], references: [id])
  avatarForId Int?

  post     Post? @relation(fields: [postId], references: [id])
  postId   Int?

  isVisible Boolean @default(true)
}

model AlbumYear {
  id    Int @id @default(autoincrement())
  year  Int @unique @default(2024)

  albums Album[]
}