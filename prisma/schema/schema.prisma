generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  firstname String?
  lastname  String?
  nickname  String?
  email     String    @unique
  password  String
  avatar    String?
  signature String?
  birthDate DateTime?
  alias     String?
  albums    Album[]
}

model Album {
  id        Int       @id @default(autoincrement())
  title     String
  isVisible Boolean   @default(true)
  authorId  Int
  topicId   Int
  yearId    Int
  year      AlbumYear @relation(fields: [yearId], references: [id])
  topic     Tag       @relation(fields: [topicId], references: [id])
  author    User      @relation(fields: [authorId], references: [id])
  photos    Photo[]
}

model Photo {
  id       Int    @id @default(autoincrement())
  filename String
  albumId  Int
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String
  albums Album[]
}

model AlbumYear {
  id     Int     @id @default(autoincrement())
  year   Int     @unique
  albums Album[]
}
