// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User{
    id          Int         @id @default(autoincrement())
    firstname   String?
    lastname    String?
    nickname    String?
    alias       String?
    email       String      @unique
    password    String
    avatar      String?
    signature   String?
    birthDate   DateTime?
    albums      Album[]
}

model Album {
  id          Int         @id @default(autoincrement())
  isVisible   Boolean     
  author      User @relation(fields: [authorId], references: [id])
  authorId    Int
  topic       Tag @relation(fields: [topicId], references: [id])
  topicId     Int
  createdAt   CreatedAt @relation(fields: [dateId], references: [id])
  dateId      Int
  photos      Photo[]
}
model Photo{
  id          Int         @id @default(autoincrement())
  filename    String
  file        String
  album       Album @relation(fields: [albumId], references: [id])
  albumId     Int
}
model Tag {
  id          Int         @id @default(autoincrement())
  name        String
  albums      Album[]
}

model CreatedAt{
  id          Int         @id @default(autoincrement())
  createdAt DateTime
  albums      Album[]
}