// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User {
  id          Int      @id @default(autoincrement())
  firstname   String?
  lastname    String?
  nickname    String?
  alias       String?
  email       String   @unique
  password    String

  signature   String?
  birthDate   DateTime?

  albums      Album[]
  photos      Photo[]
  avatars     Photo[]  @relation("UserAvatars")
}

model Album {
  id        Int      @id @default(autoincrement())
  title     String
  isVisible Boolean  @default(true)

  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int

  topic     Tag      @relation(fields: [topicId], references: [id]) 
  topicId   Int

  year      AlbumYear @relation(fields: [yearId], references: [id]) 
  yearId    Int

  photos    Photo[]
}
model Photo {
  id        Int     @id @default(autoincrement())
  filename  String
  
  album     Album?  @relation(fields: [albumId], references: [id])
  albumId   Int?

  user      User?   @relation(fields: [userId], references: [id])
  userId    Int?

  avatarFor User?   @relation("UserAvatars", fields: [avatarForId], references: [id])
  avatarForId Int?

  isVisible Boolean @default(true)
}
model Tag {
  id          Int         @id @default(autoincrement())
  name        String      @default("Nature")
  albums      Album[]
}

model AlbumYear {
  id    Int @id @default(autoincrement())
  year  Int @unique @default(2024)

  albums Album[]
}