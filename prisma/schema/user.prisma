model User {
  id          Int      @id @default(autoincrement())
  firstname   String?
  lastname    String?
  nickname    String?
  alias       String?
  email       String   @unique
  password    String

  signature   String?
  birthDate   DateTime?

  albums      Album[]
  photos      Photo[]
  avatars     Photo[]  @relation("UserAvatars")
  posts       Post[]
}